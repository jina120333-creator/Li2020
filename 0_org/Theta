FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      Theta;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e-6; //0;

boundaryField
{
    "(sideWalls|bottom|pier)"
    {
        type            zeroGradient;
    }
    /*"(sideWalls|bottom|top|pier)"
    {
        type            zeroGradient;
    }*/
    top
    {
        //type symmetryPlane;
        type            zeroGradient;
    }
    inletWater
    {
	         type fixedValue;
            value uniform 1e-6;
    }
    inletSediment
    {
	        type fixedValue;
            value uniform 1e-6;
    }
    outletWater
    {
        type            zeroGradient;
    }
    outletSediment
    {
        type            zeroGradient;
    }

}


