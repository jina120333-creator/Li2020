FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rbgh;
}
// * * * * * * * * * * * *``` * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;	//0;

boundaryField
{
    "(sideWalls|bottom|pier)"
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
    top
    {
		type    		symmetryPlane;
        /*
        type            fixedFluxPressure;
        value           uniform 0;
        value           uniform 0;
        type            totalPressure;
        p0              uniform 0;
        */
    }
    inletWater
    {
        type            zeroGradient;
    }
    inletSediment
    {
        type            zeroGradient;
    }
    outletWater
    {
//        type            zeroGradient;
        type            fixedValue;
        value           uniform 0;
    }
    outletSediment
    {
        // Must NOT be fixedValue 0: inside the bed p_rbgh carries the
        // buoyant sediment load during consolidation/scour transients.
        // Pinning it to 0 at this face creates a huge horizontal pressure
        // gradient that sucks pore water out of the bed. The pressure
        // reference stays on outletWater (fixedValue 0).
        type            fixedFluxPressure;
        value           uniform 0;
    }

}
