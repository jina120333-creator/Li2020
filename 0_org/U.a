FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=64;scalar=64";
    class       volVectorField;
    location    "0";
    object      U.a;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inletWater
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    inletSediment
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
    outletWater
    {
        type			inletOutlet;
		inletValue		uniform (0 0 0);
		value			uniform (0 0 0);
		//type            zeroGradient;
//        type            fixedValue;
//        value           uniform (0 0 0);
    }
    outletSediment
    {
        type			inletOutlet;
		inletValue		uniform (0 0 0);
		value			uniform (0 0 0);
        //type            zeroGradient;
        //type            fixedValue;
        //value           uniform (0 0 0);
    }
    "(sideWalls|bottom|pier)"
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }
	top	
	{
		type			zeroGradient; //slip; //zeroGradient;
        //type        symmetryPlane;
	}
}

// ************************************************************************* //
