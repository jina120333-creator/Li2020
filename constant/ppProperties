FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      ppProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


ppModel          JohnsonJackson;

// alphaMax must not exceed alphaMaxG (granularRheologyProperties, 0.61):
// the MuI shear-induced pressure diverges as alpha -> alphaMaxG, so the
// frictional pressure has to stop compaction before that limit is reached.
// With 0.635 the static bed compacts to alpha ~ 0.62 under its own weight
// and pa blows up (observed 3.7e7 Pa).
alphaMax         alphaMax [ 0 0 0 0 0 0 0 ] 0.61;

alphaMinFriction alphaMinFriction [ 0 0 0 0 0 0 0 ] 0.57;

Fr               Fr [ 1 -1 -2 0 0 0 0 ] 5e-2;

eta0             eta0 [ 0 0 0 0 0 0 0 ] 3;

eta1             eta1 [ 0 0 0 0 0 0 0 ] 5;


packingLimiter  no;


