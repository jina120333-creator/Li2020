FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     sedFoam;

startFrom       latestTime; //startTime;

startTime       startFrom;

stopAt          endTime;

endTime         100; //300; // t* = 11 corresponds to approximately 300 s.

deltaT          1e-4;

writeControl    adjustableRunTime;

writeInterval   0.1;//0.05; 

//purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

// Conservative Courant number for sediment-water coupled calculation.
maxCo           0.5;//1;//0.25; //0.5; //range 0.5-1.0

maxAlphaCo      0.5;//1;//0.3; //0.5; 

// Maximum allowed time step.
// With local refined cells of about 0.625 mm and U0 = 0.233 m/s,
// dt around 5e-4 to 7e-4 s gives Co around 0.2-0.3.
// The bed consolidation (pff-alpha coupling) is stiff: at dt ~ 1.5e-3 the
// contact pressure oscillated by a factor ~15 between PIMPLE iterations
// (pff 27.6k -> 33k -> 5k -> 1.9k -> ... -> 25.4k) and alpha ratcheted up
// to alphaMax. Keep dt <= 1e-3 at least until the bed has settled.
maxDeltaT       1e-3; //3e-3; //5e-4; //2e-4;

libs (
"libturbulenceModels.so"
"libgroovyBC.so"
"libgroovyStandardBCs.so"
     );

OptimisationSwitches
  {
      //- Parallel IO file handler
      // uncollated (default), collated or masterUncollated
      fileHandler collated;

      //- collated: thread buffer size for queued file writes.
      // If set to 0 or not sufficient for the file size threading is not used.
      // Default: 2e9
      maxThreadFileBufferSize 0;

      //- masterUncollated: non-blocking buffer size.
      // If the file exceeds this buffer size scheduled transfer is used.
      // Default: 2e9
      maxMasterFileBufferSize 2e9;
  }

/*DebugSwitches
{
    dimensionSet    0;
}*/

functions
{
    alphaMonitor
    {
        type            fieldMinMax;
        libs            (fieldFunctionObjects);
        fields          (alpha.a);
        location        yes;
        writeControl    timeStep;
        writeInterval   10;
    }

    // Track WHERE the granular pressures and sediment velocity peak:
    // pa parked at ~17.5 kPa in a quasi-static bed means the cell sits in
    // the clamped mu(I) singular zone (alpha > alphaMaxG); the location
    // tells immediately whether it is the bed bottom, the pier wall, or
    // an inlet/outlet face.
    granularMonitor
    {
        type            fieldMinMax;
        libs            (fieldFunctionObjects);
        fields          (pa U.a);
        location        yes;
        writeControl    timeStep;
        writeInterval   10;
    }

    // The standard yPlus functionObject cannot be used with sedFoam:
    // it looks up "turbulenceProperties" while sedFoam registers the
    // fluid-phase model as "turbulenceProperties.b". Instead, compute
    // y+ directly from the wall-normal gradient of U.b on wall patches.
    yPlusWalls
    {
        type            coded;
        libs            (utilityFunctionObjects);
        name            yPlusWalls;
        writeControl    adjustableRunTime;
        writeInterval   0.1;

        codeInclude
        #{
            #include "wallFvPatch.H"
        #};

        codeWrite
        #{
            const volVectorField& Ub =
                mesh().lookupObject<volVectorField>("U.b");
            const volScalarField& nutb =
                mesh().lookupObject<volScalarField>("nut.b");

            const scalar nu = 1e-06;

            forAll(mesh().boundary(), patchi)
            {
                const fvPatch& fvp = mesh().boundary()[patchi];

                // Note: no size() guard here - gMin/gAverage/gMax are
                // collective reductions and must run on every processor,
                // including those holding zero faces of this patch.
                if (isA<wallFvPatch>(fvp))
                {
                    const scalarField nuEffw(nutb.boundaryField()[patchi] + nu);
                    const vectorField snGradUw(Ub.boundaryField()[patchi].snGrad());
                    const scalarField uTau(sqrt(nuEffw*mag(snGradUw)));
                    const scalarField yc(1.0/fvp.deltaCoeffs());
                    const scalarField yPlus(uTau*yc/nu);

                    Info<< "yPlus on " << fvp.name()
                        << " : min = " << gMin(yPlus)
                        << ", avg = " << gAverage(yPlus)
                        << ", max = " << gMax(yPlus) << endl;
                }
            }
        #};
    }
}
