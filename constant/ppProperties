FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      ppProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


ppModel          JohnsonJackson;

// Random close packing limit. Must stay consistent with alphaMaxG in
// granularRheologyProperties (also 0.635): if alphaMaxG < alphaMax, every
// alpha in (alphaMaxG, alphaMax] puts the MuI shear-induced pressure past
// its singularity. Also keep the initial bed fraction (setFieldsDict) close
// to the self-weight equilibrium (~0.612 at z=-0.06) so consolidation does
// not overshoot into the MULES cap at alphaMax, where pff is clamped at
// Fr*(alphaMax-alphaMinFriction)^eta0/(1e-3)^eta1 = 1.37e10 and ejects cells.
alphaMax         alphaMax [ 0 0 0 0 0 0 0 ] 0.635;

alphaMinFriction alphaMinFriction [ 0 0 0 0 0 0 0 ] 0.57;

Fr               Fr [ 1 -1 -2 0 0 0 0 ] 5e-2;

eta0             eta0 [ 0 0 0 0 0 0 0 ] 3;

eta1             eta1 [ 0 0 0 0 0 0 0 ] 5;


packingLimiter  no;


