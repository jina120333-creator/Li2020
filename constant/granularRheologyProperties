FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      granaularRheologyProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

granularRheology   on;//off;

granularDilatancy  off;

granularCohesion  off;

// alphaMaxG is the maximum packing fraction of the mu(I) rheology:
// the static-bed equilibrium concentration tends to alphaMaxG as I -> 0.
// It MUST stay strictly below alphaMax (0.635) in ppProperties, because the
// JohnsonJackson contact pressure pff ~ 1/(alphaMax - alpha)^eta1 is singular
// at alphaMax. Setting alphaMaxG = 0.635 makes the bed compact exactly into
// that singularity (pff -> 1e10) and guarantees divergence. Keep at 0.61.
alphaMaxG       alphaMaxG [ 0 0 0 0 0 0 0 ] 0.61;

mus             mus  [ 0 0 0 0 0 0 0 ] 0.35;

mu2             mu2  [ 0 0 0 0 0 0 0 ] 0.97;

I0              I0  [ 0 0 0 0 0 0 0 ] 0.69;

Bphi            Bphi [ 0 0 0 0 0 0 0 ] 0.31;

n               n [ 0 0 0 0 0 0 0 ] 2.5;

Dsmall          Dsmall [ 0 0 -1 0 0 0 0 ] 1e-4;

relaxPa         relaxPa [ 0 0 0 0 0 0 0 ] 1;

FrictionModel   MuI;

//PPressureModel  none;
PPressureModel  MuI;

FluidViscosityModel BoyerEtAl;

// ************************************************************************* //
