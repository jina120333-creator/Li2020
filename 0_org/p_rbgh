FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p_rbgh;
}
// * * * * * * * * * * * *``` * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;	//0;

boundaryField
{
    "(sideWalls|bottom|pier)"
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
    top
    {
		type    		symmetryPlane;
        /*
        type            fixedFluxPressure;
        value           uniform 0;
        value           uniform 0;
        type            totalPressure;
        p0              uniform 0;
        */
    }
    inletWater
    {
        type            zeroGradient;
    }
    inletSediment
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }
    outletWater
    {
//        type            zeroGradient;
        type            fixedValue;
        value           uniform 0;
    }
    // Inside the bed the equilibrium p_rbgh is NOT zero:
    // p_rbgh(z) ~ alpha*(rho_a - rho_b)*g*(0 - z), i.e. up to ~560 Pa at
    // z = -0.06. Fixing 0 here creates a permanent ~560 Pa horizontal
    // pressure imbalance that sucks pore water out through this face
    // (Ub ~ 1 m/s) while U.a = 0 traps the grains, so the bed compacts
    // against the outlet until alpha hits alphaMax and pff/pa blow up.
    outletSediment
    {
        type            fixedFluxPressure;
        value           uniform 0;
    }

}
