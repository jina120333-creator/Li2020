FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volScalarFieldValue alpha.a 0
);

regions
(
    boxToCell
    {
        box (-0.81 -0.1251 -0.061) (0.6 0.1251 0.0);

        fieldValues
        (
            // Start the bed near its frictional (JohnsonJackson) self-weight
            // equilibrium (~0.612 at the bottom with alphaMax = 0.635).
            // Starting loose at 0.58 makes the whole bed consolidate from
            // t = 0; the stiff pff-alpha coupling oscillates and the
            // un-relaxed final PIMPLE iteration ratchets alpha up to the
            // MULES cap (0.635) within ~10 ms, where pff = 1.37e10 kills
            // the run.
            volScalarFieldValue alpha.a 0.60 //0.58
        );
    }

